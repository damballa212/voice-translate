# OpenAI gpt-realtime-translate — real-time voice translation
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# SQLite database path (default: app.db)
# DB_PATH=app.db

# Trial limit: max free recordings per user. 0 = unlimited.
# TRIAL_LIMIT=3

# Web Push / PWA notifications. Generate a VAPID keypair before enabling.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIM_EMAIL=admin@example.com

# HTTP/WS port (default: 8800)
# PORT=8800

# --- Traducción de texto (DM messaging) ---
# LiteLLM model string. Ejemplos:
#   deepseek/deepseek-chat          (DeepSeek — requiere DEEPSEEK_API_KEY)
#   openai/gpt-4o-mini              (OpenAI — requiere OPENAI_API_KEY)
#   anthropic/claude-haiku-3-5      (Anthropic — requiere ANTHROPIC_API_KEY)
TRANSLATION_MODEL=openai/gpt-4o-mini
# Fallback si el primario falla (opcional)
TRANSLATION_FALLBACK_MODEL=
# Segundo fallback (opcional)
TRANSLATION_FALLBACK2_MODEL=
